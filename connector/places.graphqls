type Photo {
  id: String!
  widthPx: Int!
  heightPx: Int!
  authorAttributions: [AuthorAttribution!]!
  flagContentUri: String!
  googleMapsUri: String!
}
type PlusCode {
  globalCode: String!
  compoundCode: String!
}
type Attribution {
  provider: String!
  providerUri: String!
}
type GoogleMapsLinks {
  directionsUri: String!
  placeUri: String!
  writeAReviewUri: String!
  reviewsUri: String!
  photosUri: String!
}
