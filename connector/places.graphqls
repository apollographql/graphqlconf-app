#   },
#   "close": {
#     object (Point)
#   }
# }
# "Point" object type
# {
#   "date": {
#     object (Date)
#   },
#   "truncated": boolean,
#   "day": integer,
#   "hour": integer,
#   "minute": integer
# }
# "TimeZone" object type
