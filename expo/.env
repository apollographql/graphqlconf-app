# prevent Expo from loading env files and overwriting encrypted values with unencrypted ones
__EXPO_ENV=true
EXPO_PUBLIC__GRAPHQL_SERVER=http://localhost:4000/
EXPO_PUBLIC_FAKE_TIME=1757321100
EXPO_PUBLIC_CURRENT_EVENT=graphqlconf-2025
MCP_RESOURCE_URL=https://events.apollo.dev/mcp

# Api keys etc. are stored encrypted in .env.local
# set api keys with 
#```sh
# yarn dotenvx set OPENAI_API_KEY "key-contents" -f .env.local -fk ~/.dotenvx.keys 
# yarn dotenvx set OPENAI_ORG_ID "key-contents" -f .env.local -fk ~/.dotenvx.keys 
# ```