extend schema
  @link(
    url: "https://specs.apollo.dev/federation/v2.10"
    import: ["@key", "@shareable"]
  ) # Enable this schema to use Apollo Federation features
  @link( # Enable this schema to use Apollo Connectors
    url: "https://specs.apollo.dev/connect/v0.3"
    import: ["@connect", "@source"]
  )
  @source(
    name: "places"
    http: {
      baseURL: "https://places.googleapis.com/v1/"
      headers: [
        { name: "Content-Type", value: "application/json" }
        { name: "x-goog-api-key", value: "{$config.api_key}" }
      ]
    }
  )

input LocationRestrictionInput {
  latitude: Float!
  longitude: Float!
  radiusInMeters: Int!
}

type Query {
  nearbyPlaces(
    includedTypes: [NearbyPlaceType!]!
    maxResultCount: Int = 10
    locationRestriction: LocationRestrictionInput!
  ): [Place!]!
    @connect(
      source: "places"
      http: {
        POST: "places:searchNearby"
        body: """
        includedTypes: $args.includedTypes
        maxResultCount: $args.maxResultCount
        locationRestriction: {
          circle: {
            center: {
              latitude: $args.locationRestriction.latitude
              longitude: $args.locationRestriction.longitude
            }
            radius: $args.locationRestriction.radiusInMeters
          }
        }
        """
        headers: [
          {
            name: "X-Goog-FieldMask"
            value: "places.id,places.displayName,places.primaryTypeDisplayName,places.formattedAddress,places.location,places.viewport"
          }
        ]
      }
      selection: """
      $.places {
          id
          displayName { text languageCode }
          primaryTypeDisplayName { text languageCode }
          formattedAddress
          location { latitude longitude }
          viewport { low { latitude longitude } high { latitude longitude } }
      }
      """
    )

  place(id: String!): Place
    @connect(
      source: "places"
      http: {
        GET: "places/{$args.id}"
        headers: [
          {
            name: "X-Goog-FieldMask"
            value: "name,id,displayName,types,primaryType,primaryTypeDisplayName,formattedAddress,shortFormattedAddress,postalAddress,addressComponents,plusCode,location,viewport,googleMapsUri,photos,adrFormatAddress,businessStatus,attributions,googleMapsLinks"
          }
        ]
      }
      selection: """
      ${
          name
          id
          displayName { text languageCode }
          types
          primaryType
          primaryTypeDisplayName { text languageCode }
          formattedAddress
          shortFormattedAddress
          postalAddress
          addressComponents { longText shortText types languageCode}
          plusCode { globalCode compoundCode }
          location { latitude longitude }
          viewport { low { latitude longitude } high { latitude longitude } }
          googleMapsUri
          photos { id: name widthPx heightPx authorAttributions { displayName uri photoUri } flagContentUri googleMapsUri }
          adrFormatAddress
          businessStatus
          attributions { provider providerUri }
        #   addressDescriptor {}
          googleMapsLinks {
            directionsUri
            placeUri
            writeAReviewUri
            reviewsUri
            photosUri
          }
        #   accessibilityOptions {}
      }
      """
      entity: true
    )
}

enum NearbyPlaceType {
  # https://developers.google.com/maps/documentation/places/web-service/place-types?hl=en#table-a
  acai_shop
  afghani_restaurant
  african_restaurant
