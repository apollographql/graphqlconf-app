type LocalizedText {
  text: String!
  languageCode: String!
}
type AddressComponent {
  longText: String!
  shortText: String!
  types: [String!]!
  languageCode: String!
}
type LatLng @shareable {
  latitude: Float!
  longitude: Float!
}
type Viewport {
  low: LatLng!
  high: LatLng!
}
